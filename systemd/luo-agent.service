[Unit]
Description=Luo OS Agent Service
After=network.target ollama.service
Wants=ollama.service

[Service]
Type=simple
User=%USER%
WorkingDirectory=%LUO_DIR%
ExecStart=%PYTHON% %LUO_DIR%/luo_cli.py evolution --interval 300
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

# Environment
Environment="LUO_MODEL=mistral"
Environment="OLLAMA_URL=http://localhost:11434"

# Resource limits
MemoryMax=2G
CPUQuota=100%

[Install]
WantedBy=multi-user.target